# Website Orchestrator (Milestone 0) — example environment configuration.
#
# Copy this file to `.env` and fill in real values for your environment:
#     cp .env.example .env
#
# `.env` (and any other credential-bearing file) is gitignored and MUST NEVER be
# committed (Req 14.3). Secrets are loaded from environment variables or `.env`
# at startup via pydantic-settings; a missing REQUIRED secret fails startup with
# a message naming the missing key but never its value (Req 14.1, 14.2).
#
# Legend:  [required]  must be set for the app to start
#          [secret]    credential — never commit, never log
#          [optional]  overrides a Core_Package default when set

# --- Datastore -------------------------------------------------------------
# PostgreSQL connection URL (Req 10.8). The host/port/credentials must match the
# PostgreSQL service defined in docker-compose.yml. For the default local
# compose setup (user=orchestrator, password=orchestrator, db=orchestrator):
# [required]
DATABASE_URL=postgresql+psycopg://orchestrator:orchestrator@localhost:5432/orchestrator

# --- Multi-tenancy ---------------------------------------------------------
# Tenant_Id stamped on every inserted row (Req 14.4, 14.5). A single tenant in
# Milestone 0; records with no resolvable tenant are rejected (Req 14.6).
# [required]
TENANT_ID=default

# --- WordPress Publishing_Adapter ------------------------------------------
# Base URL of the target WordPress site (the live write target).
# [required]
WP_BASE_URL=https://your-wordpress-site.example

# WordPress user for HTTP Basic authentication.
# [required]
WP_USERNAME=your-wp-username

# WordPress Application_Password used with HTTP Basic auth (Req 6.4, 6.5).
# This is a WordPress-issued Application Password, NOT the account login
# password. Never logged, never returned in responses or errors (Req 6.7, 7.5,
# 7.10, 13.4).
# [required] [secret]
WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- Threshold overrides (optional) ----------------------------------------
# When unset, each falls back to its Core_Package default shown below.
# [optional]

# Crawler per-host request pacing floor, in milliseconds (default 1000).
# RATE_LIMIT_MS=1000

# Response-time degradation threshold in milliseconds; above this the crawler
# doubles its delay (default 2000).
# DEGRADATION_THRESHOLD_MS=2000

# Per-request crawl timeout, in seconds (default 30).
# REQUEST_TIMEOUT_S=30

# check_link_status timeout, in seconds (default 10).
# LINK_TIMEOUT_S=10

# Redirect hard cap; crawler stops following past this (default 10, bounds 1-50).
# REDIRECT_HARD_CAP=10

# Minimum word count below which content is flagged as thin (default 300).
# THIN_CONTENT_MIN_WORDS=300

# Redirect-chain length at/above which a redirect-chain issue is flagged
# (default 3).
# REDIRECT_CHAIN_THRESHOLD=3

# Maximum length of heuristic alt text produced by the Fix_Generator
# (default 125).
# MAX_ALT_TEXT_LEN=125

# Maximum age of Digital_Twin page data before a re-crawl is required, e.g. an
# ISO-8601 duration or seconds depending on the config parser (Req 3.4, 3.5).
# STALENESS_THRESHOLD=3600

# --- Docker Compose PostgreSQL service credentials -------------------------
# Consumed by docker-compose.yml to initialize the local PostgreSQL container.
# Keep these consistent with DATABASE_URL above. [optional] (defaults applied)
# POSTGRES_USER=orchestrator
# POSTGRES_PASSWORD=orchestrator
# POSTGRES_DB=orchestrator
# POSTGRES_PORT=5432
